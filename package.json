{
  "name": "urnammu",
  "version": "0.1.0",
  "description": "AI Governance & Compliance Platform — centralized oversight of AI systems, agents, and API usage",
  "author": "JuanNephrota",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JuanNephrota/UrNammu.git"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate && (husky || true)",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "check:secrets": "bash scripts/check-secrets.sh",
    "check:schema-drift": "node scripts/check-schema-drift.mjs",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset": "npx prisma migrate reset --force"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored"
    ],
    "*.{js,jsx,ts,tsx,json,yml,yaml,md,env,example,sh}": [
      "bash scripts/check-secrets.sh"
    ]
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "overrides": {
    "postcss": "8.5.10",
    "qs": "6.15.2",
    "minimatch@10": {
      "brace-expansion": "5.0.6"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@azure/identity": "^4.13.1",
    "@azure/monitor-query-metrics": "^1.0.0",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crowdstrike-falcon": "^0.6.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.9.0",
    "googleapis": "^171.4.0",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.0",
    "next": "16.2.7",
    "next-auth": "^4.24.14",
    "openai": "^6.45.0",
    "prisma": "^6.19.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6"
  }
}
